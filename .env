# ══════════════════════════════════════════════════════════════════
#  PensionCTB 2.5 — Entorno LOCAL / DESARROLLO
#  Ajusta estos valores según tu configuración local.
#  ¡Este archivo NO debe subirse a git!
# ══════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────
APP_NAME="PensionCTB"
APP_ENV=local
APP_URL=https://gestorausentismos.bogotamia.com/public
APP_DEBUG=true
APP_TIMEZONE=America/Bogota

# ── Base de datos ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wbogotaw9_colegio_tesoreria
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ── Correo / SMTP ─────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=tu_contraseña_app
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tucorreo@gmail.com
MAIL_FROM_NAME="PensionCTB Local"

# ── Seguridad / Sesiones ──────────────────────────────────────────
APP_KEY=dev_key_32_chars_cambiame_ahora_
SESSION_LIFETIME=7200

# ── JWT (API) ─────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_cambiame
JWT_TTL=3600

# ── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=file
LOG_LEVEL=debug

# ── Rutas de almacenamiento ───────────────────────────────────────
STORAGE_PATH=../storage
UPLOADS_PATH=../storage/uploads