{
    "name": "pensionctb/pensionctb",
    "description": "Sistema integral de gestión de tesorería educativa para colegios colombianos",
    "type": "project",
    "keywords": ["tesoreria", "colegio", "pensiones", "pagos", "educacion", "colombia"],
    "homepage": "https://gestorausentismos.bogotamia.com/",
    "license": "proprietary",
    "authors": [
        {
            "name": "José Luis Castro Piraquive",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-gd": "*",
        "bramus/router": "^1.6",
        "dompdf/dompdf": "^3.1",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.10",
        "masterminds/html5": "^2.10",
        "monolog/monolog": "^3.10",
        "phpmailer/phpmailer": "^7.0",
        "phpoffice/phpspreadsheet": "^5.7",
        "picqer/php-barcode-generator": "^3.2",
        "respect/validation": "^2.4",
        "sabberworm/php-css-parser": "^9.3",
        "teamtnt/tntsearch": "^5.0",
        "thecodingmachine/safe": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "voku/anti-xss": "^4.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test-coverage": "phpunit --coverage-html storage/coverage"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}